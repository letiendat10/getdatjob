{
  "manifest_version": 3,
  "name": "getdatjob LinkedIn Enrichment",
  "version": "1.0.0",
  "description": "Watches the signup queue and enriches LinkedIn profiles automatically.",

  "permissions": [
    "tabs",
    "scripting",
    "alarms",
    "storage"
  ],

  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://tdgptapfspleoobiyiqx.supabase.co/*",
    "https://getdatjob.vercel.app/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://getdatjob.vercel.app/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_title": "getdatjob enrichment",
    "default_popup": "popup.html"
  }
}
